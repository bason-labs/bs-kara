{
  "rules": {
    "meta": {
      "activeRoom": {
        ".read": true,
        ".write": true,
        ".validate": "newData.val() === null || (newData.isString() && newData.val().matches(/^[0-9]{4}$/))"
      },
      "$other": { ".validate": false }
    },

    "rooms": {
      "$roomId": {
        ".read": "$roomId.matches(/^[0-9]{4}$/)",
        ".write": "$roomId.matches(/^[0-9]{4}$/)",

        "queue": {
          "$queueId": {
            ".validate": "newData.hasChildren(['id', 'title', 'channel', 'thumbnail', 'duration'])",
            "id":            { ".validate": "newData.isString() && newData.val().length <= 64" },
            "title":         { ".validate": "newData.isString() && newData.val().length <= 500" },
            "channel":       { ".validate": "newData.isString() && newData.val().length <= 200" },
            "thumbnail":     { ".validate": "newData.isString() && newData.val().length <= 500" },
            "duration":      { ".validate": "newData.isString() && newData.val().length <= 16" },
            "requesterName": { ".validate": "newData.isString() && newData.val().length <= 60" },
            "mcText":        { ".validate": "newData.isString() && newData.val().length <= 500" },
            "$other":        { ".validate": false }
          }
        },

        "currentPlaying": {
          ".validate": "newData.hasChildren(['id', 'title', 'channel', 'thumbnail', 'duration'])",
          "id":            { ".validate": "newData.isString() && newData.val().length <= 64" },
          "title":         { ".validate": "newData.isString() && newData.val().length <= 500" },
          "channel":       { ".validate": "newData.isString() && newData.val().length <= 200" },
          "thumbnail":     { ".validate": "newData.isString() && newData.val().length <= 500" },
          "duration":      { ".validate": "newData.isString() && newData.val().length <= 16" },
          "requesterName": { ".validate": "newData.isString() && newData.val().length <= 60" },
          "mcText":        { ".validate": "newData.isString() && newData.val().length <= 500" },
          "$other":        { ".validate": false }
        },

        "history": {
          "$idx": {
            ".validate": "newData.hasChildren(['id', 'title', 'channel', 'thumbnail', 'duration'])",
            "id":            { ".validate": "newData.isString() && newData.val().length <= 64" },
            "title":         { ".validate": "newData.isString() && newData.val().length <= 500" },
            "channel":       { ".validate": "newData.isString() && newData.val().length <= 200" },
            "thumbnail":     { ".validate": "newData.isString() && newData.val().length <= 500" },
            "duration":      { ".validate": "newData.isString() && newData.val().length <= 16" },
            "requesterName": { ".validate": "newData.isString() && newData.val().length <= 60" },
            "mcText":        { ".validate": "newData.isString() && newData.val().length <= 500" },
            "$other":        { ".validate": false }
          }
        },

        "playedHistory": {
          "$idx": { ".validate": "newData.isString() && newData.val().length <= 64" }
        },

        "isPlaying":              { ".validate": "newData.isBoolean()" },
        "isAutoRandomMode":       { ".validate": "newData.isBoolean()" },
        "randomFilters": {
          "type":  { ".validate": "newData.isString() && newData.val().matches(/^(all|solo|duet)$/)" },
          "tone":  { ".validate": "newData.isString() && newData.val().matches(/^(all|male|female)$/)" },
          "genre": { ".validate": "newData.isString() && newData.val().matches(/^(all|bolero|caco|tre)$/)" },
          "$other": { ".validate": false }
        },
        "dragDropEnabled":        { ".validate": "newData.isBoolean()" },
        "requesterPromptEnabled": { ".validate": "newData.isBoolean()" },
        "isMCEnabled":            { ".validate": "newData.isBoolean()" },
        "isAImcEnabled":          { ".validate": "newData.isBoolean()" },
        "mcVoice":                { ".validate": "newData.isString() && newData.val().length <= 64" },
        "lastAnnouncedSongId":    { ".validate": "newData.isString() && newData.val().length <= 64" },
        "isTvActive":             { ".validate": "newData.isBoolean()" },
        "fullscreenOwner":        { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 64)" },
        "lastEndedAt":            { ".validate": "newData.isNumber()" },

        "emojis": {
          ".indexOn": ["timestamp"],
          "$emojiId": {
            ".validate": "newData.hasChildren(['emoji', 'timestamp'])",
            "emoji":     { ".validate": "newData.isString() && newData.val().length <= 16" },
            "timestamp": { ".validate": "newData.isNumber()" },
            "$other":    { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "admins": {
      "emails": {
        ".read": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
        "$emailKey": {
          ".write": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
          ".validate": "newData.hasChildren(['uid', 'addedAt'])",
          "uid":     { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
          "addedAt": { ".validate": "newData.isNumber()" },
          "$other":  { ".validate": false }
        }
      },
      "$other": { ".validate": false }
    },

    "subscriptions": {
      ".read": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
      ".write": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
      ".indexOn": ["userPhone", "endDate", "status", "type", "source"],
      "$subscriptionId": {
        ".validate": "newData.hasChildren(['userPhone', 'type', 'status', 'durationDays', 'startDate', 'endDate', 'source', 'createdAt', 'updatedAt'])",
        "userPhone":    { ".validate": "newData.isString() && newData.val().matches(/^\\+84[0-9]{9}$/)" },
        "userId":       { ".validate": "newData.val() === null || (newData.isString() && newData.val().length > 0 && newData.val().length <= 128)" },
        "type":         { ".validate": "newData.isString() && newData.val().matches(/^(trial|paid)$/)" },
        "status":       { ".validate": "newData.isString() && newData.val().matches(/^(active|cancelled)$/)" },
        "durationDays": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 365" },
        "startDate":    { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "endDate":      { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "source":       { ".validate": "newData.isString() && newData.val().matches(/^(manual_admin|self_register_phone|payment_webhook)$/)" },
        "paymentRef":   { ".validate": "newData.val() === null || (newData.isString() && newData.val().length > 0 && newData.val().length <= 128)" },
        "createdBy":    { ".validate": "newData.val() === null || (newData.isString() && newData.val().length > 0 && newData.val().length <= 128)" },
        "createdAt":    { ".validate": "newData.isNumber()" },
        "updatedAt":    { ".validate": "newData.isNumber()" },
        "$other":       { ".validate": false }
      }
    },

    "subscriptionsByPhone": {
      ".read": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
      ".write": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
      "$phone": {
        ".validate": "$phone.matches(/^\\+84[0-9]{9}$/)",
        "$id": { ".validate": "newData.isBoolean() && newData.val() === true" }
      }
    },

    "subscriptionTrialClaimed": {
      ".read": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists()",
      "$phone": {
        ".write": "auth != null && auth.token.email != null && root.child('admins/emails/' + auth.token.email.toLowerCase().replace('.', ',')).exists() && (!data.exists() || newData.val() === true)",
        ".validate": "$phone.matches(/^\\+84[0-9]{9}$/) && newData.isBoolean() && newData.val() === true"
      }
    },

    "$other": { ".validate": false }
  }
}
