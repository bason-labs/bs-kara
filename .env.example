# Public Firebase config (shared between client RTDB and client Auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# YouTube BFF: comma-separated, rotated automatically on 403
YOUTUBE_API_KEYS=

# AI MC + TTS
AI_MC_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_TTS_API_KEY=

# Admin site (Phase 1)
# Comma-separated list of allowlisted admin emails. Whitespace-trimmed,
# case-insensitive. An admin must (a) authenticate with Firebase Auth and
# (b) carry an email present in this list.
ADMIN_EMAILS=

# Firebase Admin SDK service-account credentials. On Vercel, paste the
# service-account JSON values into these three env vars; PRIVATE_KEY uses
# \n escapes for newlines which are restored at init.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
